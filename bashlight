#!/usr/bin/env bash
#
# bashlight - adjust backlight brightness in bash.

set -euo pipefail

readonly VERSION=0.5.0
readonly MIN_BRIGHTNESS=1 # safe value to avoid a pitch-black screen
readonly BACKLIGHT_DIR=${BACKLIGHT_DIR:-/sys/class/backlight}
readonly LEDS_DIR=${LEDS_DIR:-/sys/class/leds}
readonly STATE_DIR=${XDG_RUNTIME_DIR:-${TMPDIR:-/tmp}}/bashlight-$UID

# Disable unicode for speed
LC_ALL=C
LANG=C

die() {
	printf 'error: %s\n' "$1" >&2
	exit 1
}

find_devices() {
	local kbd=${1:-0}

	if [[ $kbd -eq 1 ]]; then
		[[ -d $LEDS_DIR ]] || die "led interface not available"
		devices=("$LEDS_DIR"/*kbd_backlight)
		[[ -e "${devices[0]}" ]] || die "no keyboard backlight devices found"
	else
		[[ -d $BACKLIGHT_DIR ]] || die "backlight interface not available"
		devices=("$BACKLIGHT_DIR"/*)
		[[ -e "${devices[0]}" ]] || die "no backlight devices found"
	fi
}

validate_percentage() {
	local value=$1
	[[ $value =~ ^[0-9]+$ ]] || die "'$value' is not a valid number"
	value=$((10#$value)) # force decimal, leading zeros would parse as octal
	[[ $value -ge 0 && $value -le 100 ]] || die "percentage must be between 0-100"
}

validate_positive_integer() {
	local value=$1 name=$2
	[[ $value =~ ^[0-9]+$ ]] || die "'$value' is not a valid number for $name"
	value=$((10#$value))
	[[ $value -gt 0 ]] || die "$name must be greater than 0"
}

validate_device() {
	local device=$1 kbd=${2:-0}
	[[ -n $device ]] || return 0

	if [[ $kbd -eq 1 ]]; then
		[[ $device == *kbd_backlight && -d $LEDS_DIR/$device ]] || die "no such keyboard backlight: $device"
	else
		[[ -d $BACKLIGHT_DIR/$device ]] || die "no such device: $device"
	fi
}

list_devices() {
	local kbd=${1:-0}
	find_devices "$kbd"

	for device_path in "${devices[@]}"; do
		printf '%s\n' "${device_path##*/}"
	done
}

get_brightness() {
	local device=${1:-} kbd=${2:-0} perceptual=${3:-0}
	find_devices "$kbd"
	validate_device "$device" "$kbd"

	for device_path in "${devices[@]}"; do
		[[ -z $device || ${device_path##*/} == "$device" ]] || continue
		[[ -r "$device_path/max_brightness" ]] || continue

		# Not every driver exposes actual_brightness
		local actual_file="$device_path/actual_brightness"
		[[ -r $actual_file ]] || actual_file="$device_path/brightness"
		[[ -r $actual_file ]] || continue

		local max actual actual_percent
		max=$(<"$device_path/max_brightness")
		[[ $max -gt 0 ]] || continue
		actual=$(<"$actual_file")
		actual_percent=$(level_to_percent "$actual" "$max" "$perceptual")

		printf '%s: %d%% (%d/%d)\n' "${device_path##*/}" "$actual_percent" "$actual" "$max"
	done
}

save_brightness() {
	local device=${1:-} kbd=${2:-0}
	find_devices "$kbd"
	validate_device "$device" "$kbd"

	local class=backlight
	[[ $kbd -eq 1 ]] && class=leds
	mkdir -p "$STATE_DIR/$class"

	local saved=0
	for device_path in "${devices[@]}"; do
		[[ -z $device || ${device_path##*/} == "$device" ]] || continue

		# Not every driver exposes actual_brightness
		local actual_file="$device_path/actual_brightness"
		[[ -r $actual_file ]] || actual_file="$device_path/brightness"
		[[ -r $actual_file ]] || continue

		printf '%s\n' "$(<"$actual_file")" >"$STATE_DIR/$class/${device_path##*/}"
		saved=$((saved + 1))
	done

	[[ $saved -gt 0 ]] || die "no readable backlight devices to save"
}

restore_brightness() {
	local time=${1:-200} steps=${2:-20} device=${3:-} kbd=${4:-0}
	find_devices "$kbd"
	validate_device "$device" "$kbd"

	local class=backlight floor=$MIN_BRIGHTNESS
	if [[ $kbd -eq 1 ]]; then
		class=leds
		floor=0
	fi

	# Pure bash floating-point calculation
	local delay restored=0
	delay=$(printf %.6f "$((10 ** 3 * time / steps))e-6")

	for device_path in "${devices[@]}"; do
		[[ -z $device || ${device_path##*/} == "$device" ]] || continue
		local state_file="$STATE_DIR/$class/${device_path##*/}"
		[[ -r $state_file ]] || continue
		[[ -r "$device_path/max_brightness" ]] || continue
		[[ -w "$device_path/brightness" ]] || continue

		# Not every driver exposes actual_brightness
		local actual_file="$device_path/actual_brightness"
		[[ -r $actual_file ]] || actual_file="$device_path/brightness"
		[[ -r $actual_file ]] || continue

		local max actual target
		max=$(<"$device_path/max_brightness")
		[[ $max -gt 0 ]] || continue
		actual=$(<"$actual_file")
		target=$(clamp "$(<"$state_file")" "$floor" "$max")
		restored=$((restored + 1))

		# Skip if no change needed
		[[ $target -eq $actual ]] && continue

		fade_to "$device_path" "$actual" "$target" "$steps" "$delay"
	done

	[[ $restored -gt 0 ]] || die "nothing saved to restore"
}

fade_to() {
	local device_path=$1 actual=$2 target=$3 steps=$4 delay=$5
	local increment next_level

	# Calculate incremental value - ensure it's not zero
	increment=$(((target - actual) / steps))
	[[ $increment -eq 0 ]] && increment=$([[ $target -gt $actual ]] && echo 1 || echo -1)

	# Transition smoothly to target
	for ((i = 1; i <= steps; i++)); do
		if [[ $i -eq $steps ]]; then
			# Ensure we hit the exact target on the final step
			next_level=$target
		else
			next_level=$((actual + increment))
			# Never step past the target
			if [[ $increment -gt 0 && $next_level -gt $target ]] ||
				[[ $increment -lt 0 && $next_level -lt $target ]]; then
				next_level=$target
			fi
		fi

		printf '%s' "$next_level" >"$device_path/brightness"
		actual=$next_level

		[[ $actual -eq $target ]] && break

		# Sleep between steps
		read -rt "$delay" <> <(:) || :
	done
}

set_brightness() {
	local operation=$1 time=${2:-200} steps=${3:-20} device=${4:-} kbd=${5:-0} perceptual=${6:-0}
	find_devices "$kbd"
	validate_device "$device" "$kbd"

	# Keyboard backlights may switch off entirely
	local floor=$MIN_BRIGHTNESS
	[[ $kbd -eq 1 ]] && floor=0

	# Pure bash floating-point calculation
	local delay writable=0
	delay=$(printf %.6f "$((10 ** 3 * time / steps))e-6")

	for device_path in "${devices[@]}"; do
		[[ -z $device || ${device_path##*/} == "$device" ]] || continue
		[[ -r "$device_path/max_brightness" ]] || continue
		[[ -w "$device_path/brightness" ]] || continue

		# Not every driver exposes actual_brightness
		local actual_file="$device_path/actual_brightness"
		[[ -r $actual_file ]] || actual_file="$device_path/brightness"
		[[ -r $actual_file ]] || continue
		writable=$((writable + 1))

		local max actual target percent
		max=$(<"$device_path/max_brightness")
		[[ $max -gt 0 ]] || continue
		actual=$(<"$actual_file")

		case $operation in
		=*) percent=${operation#=} ;;
		+*) percent=$(clamp $(($(level_to_percent "$actual" "$max" "$perceptual") + ${operation#+})) 0 100) ;;
		-*) percent=$(clamp $(($(level_to_percent "$actual" "$max" "$perceptual") - ${operation#-})) 0 100) ;;
		*) die "value '$operation' not processable" ;;
		esac
		target=$(clamp "$(percent_to_level "$percent" "$max" "$perceptual")" "$floor" "$max")

		# Skip if no change needed
		[[ $target -eq $actual ]] && continue

		fade_to "$device_path" "$actual" "$target" "$steps" "$delay"
	done

	[[ $writable -gt 0 ]] || die "no writable backlight devices (is your user in the video group?)"
}

clamp() {
	local value min max

	[[ $1 =~ ^-?[0-9]+$ ]] || die "'$1' is not a number"
	min=$2
	max=$3

	if [[ "$1" -lt $min ]]; then
		value=$min
	elif [[ "$1" -gt $max ]]; then
		value=$max
	else
		value=$1
	fi

	printf '%s\n' "$value"
}

isqrt() {
	local n=$1 x guess

	if [[ $n -lt 2 ]]; then
		printf '%s\n' "$n"
		return
	fi

	x=$n
	guess=$(((x + 1) / 2))
	while [[ $guess -lt $x ]]; do
		x=$guess
		guess=$(((x + n / x) / 2))
	done
	printf '%s\n' "$x"
}

percent_to_level() {
	local percent=$1 max=$2 perceptual=${3:-0}
	if [[ $perceptual -eq 1 ]]; then
		# Square curve approximates human brightness perception
		printf '%s\n' $((max * percent * percent / 10000))
	else
		printf '%s\n' $((percent * max / 100))
	fi
}

level_to_percent() {
	local level=$1 max=$2 perceptual=${3:-0}
	if [[ $perceptual -eq 1 ]]; then
		isqrt $((10000 * level / max))
	else
		printf '%s\n' $((level * 100 / max))
	fi
}

print_usage() {
	printf %s "\
usage: ${0##*/} [options]
where options are:
  -help                    Print out a summary of the usage and exit
  -version                 Print out the program version and exit
  -get                     Print out the current brightness of each output
  -list                    Print out the backlight device names
  -set <percentage>        Sets each backlight brightness to the specified level
  -inc <percentage>        Increases brightness by the specified amount
  -dec <percentage>        Decreases brightness by the specified amount
  -save                    Save the current brightness of each output
  -restore                 Restore the last saved brightness
  -device <name>           Apply the operation to the given device only
  -kbd                     Control keyboard backlights instead of displays
  -perceptual              Map percentages to a perceptual brightness curve
  -time <milliseconds>     Duration of transition to new value. Default is 200
  -steps <steps>           Number of transition steps. Default is 20
"
}

print_version() {
	printf "%s v%s\n" "${0##*/}" "$VERSION"
}

parse_args() {
	# Default values
	local action='' value='' device='' kbd=0 perceptual=0 time=200 steps=20

	while [[ $# -gt 0 ]]; do
		case $1 in
		-help)
			print_usage
			exit 0
			;;
		-version)
			print_version
			exit 0
			;;
		-get)
			[[ -z $action ]] || die "cannot combine -get with -$action"
			action='get'
			shift
			;;
		-list)
			[[ -z $action ]] || die "cannot combine -list with -$action"
			action='list'
			shift
			;;
		-save)
			[[ -z $action ]] || die "cannot combine -save with -$action"
			action='save'
			shift
			;;
		-restore)
			[[ -z $action ]] || die "cannot combine -restore with -$action"
			action='restore'
			shift
			;;
		-set | -inc | -dec)
			[[ -z $action ]] || die "cannot combine $1 with -$action"
			[[ -n ${2:-} ]] || die "missing percentage for $1"
			validate_percentage "$2"
			action=${1#-}
			value=$((10#$2))
			shift 2
			;;
		-device)
			[[ -n ${2:-} ]] || die "missing name for -device"
			device=$2
			shift 2
			;;
		-kbd)
			kbd=1
			shift
			;;
		-perceptual)
			perceptual=1
			shift
			;;
		-time)
			[[ -n ${2:-} ]] || die "missing value for -time"
			validate_positive_integer "$2" "time"
			time=$((10#$2))
			shift 2
			;;
		-steps)
			[[ -n ${2:-} ]] || die "missing value for -steps"
			validate_positive_integer "$2" "steps"
			steps=$((10#$2))
			shift 2
			;;
		*)
			die "unknown option: $1"
			;;
		esac
	done

	case $action in
	get) get_brightness "$device" "$kbd" "$perceptual" ;;
	list) list_devices "$kbd" ;;
	save) save_brightness "$device" "$kbd" ;;
	restore) restore_brightness "$time" "$steps" "$device" "$kbd" ;;
	set) set_brightness "=$value" "$time" "$steps" "$device" "$kbd" "$perceptual" ;;
	inc) set_brightness "+$value" "$time" "$steps" "$device" "$kbd" "$perceptual" ;;
	dec) set_brightness "-$value" "$time" "$steps" "$device" "$kbd" "$perceptual" ;;
	*) print_usage ;;
	esac
}

main() {
	[[ $# -eq 0 ]] && print_usage && exit 0
	parse_args "$@"
}

main "$@"
